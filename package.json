{
  "name": "paair",
  "version": "1.0.0",
  "description": "Personal Assistant Artificial Intelligence for Ricardo - a locally hosted, privacy-first AI email agent",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "tsc --noEmit",
    "db:init": "tsx src/utils/init_db.ts",
    "setup": "bash scripts/setup.sh"
  },
  "keywords": [
    "ai",
    "email",
    "assistant",
    "local",
    "ollama",
    "privacy"
  ],
  "author": "Ricardo",
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "resend": "^4.0.0",
    "yaml": "^2.4.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
